{
  "index_patterns": [
    "sample-app-logs-*"
  ],
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 1,
      "plugins.index_state_management.policy_id": "sample-app-2day-retention",
      "plugins.index_state_management.rollover_alias": "sample-app-logs"
    },
    "mappings": {
      "properties": {
        "timestamp": {
          "type": "date",
          "format": "strict_date_optional_time||epoch_millis"
        },
        "level": {
          "type": "keyword"
        },
        "service": {
          "type": "keyword"
        },
        "message": {
          "type": "text"
        },
        "request_id": {
          "type": "keyword"
        },
        "latency_ms": {
          "type": "long"
        },
        "kubernetes": {
          "properties": {
            "namespace_name": {
              "type": "keyword"
            },
            "pod_name": {
              "type": "keyword"
            },
            "container_name": {
              "type": "keyword"
            },
            "labels": {
              "type": "object"
            }
          }
        }
      }
    }
  },
  "priority": 200
}